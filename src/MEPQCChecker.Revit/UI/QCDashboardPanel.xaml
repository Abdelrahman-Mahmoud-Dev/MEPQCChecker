<Page x:Class="MEPQCChecker.Revit.UI.QCDashboardPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:MEPQCChecker.Revit.UI.Converters"
      Background="#F5F5F5">

    <Page.Resources>
        <converters:SeverityToColorConverter x:Key="SeverityToColor" />
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Page.Resources>

    <DockPanel>
        <!-- Status bar at bottom -->
        <Border DockPanel.Dock="Bottom" Background="#E0E0E0" Padding="8,4">
            <TextBlock x:Name="StatusText" FontSize="11" Foreground="#555"
                       Text="Ready — click Run QC Check to start"/>
        </Border>

        <!-- Action bar -->
        <Border DockPanel.Dock="Bottom" Background="#EEEEEE" Padding="6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnRunCheck" Content="Run Check" Padding="16,6" Margin="4,0"
                        FontWeight="SemiBold" Click="BtnRunCheck_Click"/>
                <Button x:Name="BtnClearHighlights" Content="Clear Highlights" Padding="16,6" Margin="4,0"
                        Click="BtnClearHighlights_Click"/>
                <Button Content="Export..." Padding="16,6" Margin="4,0"
                        IsEnabled="False" ToolTip="Coming in Phase 2"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">
                <!-- Summary cards -->
                <UniformGrid Columns="3" Margin="0,0,0,8">
                    <Border Style="{StaticResource StatCard}" Background="#FDDEDE">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="CriticalCount" Text="0" FontSize="28"
                                       FontWeight="Bold" Foreground="#DC3232" HorizontalAlignment="Center"/>
                            <TextBlock Text="Critical" FontSize="12" Foreground="#AA2020"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Background="#FFF3D6">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="WarningCount" Text="0" FontSize="28"
                                       FontWeight="Bold" Foreground="#E6A000" HorizontalAlignment="Center"/>
                            <TextBlock Text="Warning" FontSize="12" Foreground="#B07C00"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Background="#E8E8E8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="InfoCount" Text="0" FontSize="28"
                                       FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center"/>
                            <TextBlock Text="Info" FontSize="12" Foreground="#888"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Filter bar -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock Text="Discipline" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                        <ComboBox x:Name="DisciplineFilter" SelectedIndex="0"
                                  SelectionChanged="Filter_Changed">
                            <ComboBoxItem Content="All"/>
                            <ComboBoxItem Content="Mechanical"/>
                            <ComboBoxItem Content="Plumbing"/>
                            <ComboBoxItem Content="FireProtection"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                        <TextBlock Text="Severity" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                        <ComboBox x:Name="SeverityFilter" SelectedIndex="0"
                                  SelectionChanged="Filter_Changed">
                            <ComboBoxItem Content="All"/>
                            <ComboBoxItem Content="Critical"/>
                            <ComboBoxItem Content="Warning"/>
                            <ComboBoxItem Content="Info"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Issue list -->
                <ListView x:Name="IssueList" MinHeight="200"
                          SelectionChanged="IssueList_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="" Width="24">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="10" Height="10"
                                                 Fill="{Binding Severity, Converter={StaticResource SeverityToColor}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Type" Width="110"
                                            DisplayMemberBinding="{Binding CheckType}"/>
                            <GridViewColumn Header="Description" Width="280"
                                            DisplayMemberBinding="{Binding Description}"/>
                            <GridViewColumn Header="ID" Width="60"
                                            DisplayMemberBinding="{Binding ElementId}"/>
                            <GridViewColumn Header="Level" Width="80"
                                            DisplayMemberBinding="{Binding Level}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
